# Local app runtime. Required for browsing country pages and vote flows now that
# vote totals are Redis-backed.
REDIS_URL=redis://localhost:4000

# Structured application logging. Supported values are fatal, error, warn, info,
# debug, trace, and silent.
LOG_LEVEL=info

# Docker Compose host ports for the local app and Redis services.
APP_HOST_PORT=3000
REDIS_HOST_PORT=4000

# Stripe webhook verification. Required only when handling Stripe webhook events.
# Use the webhook signing secret from Stripe CLI or the Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=whsec_replace_with_local_or_deployment_secret

# Stripe checkout creation. Use a Stripe test-mode secret key for local paid
# vote checkout work. Never commit live-mode keys or real secrets.
STRIPE_SECRET_KEY=sk_test_replace_with_local_test_secret

# Redis backup runner and Docker Compose backup sidecar.
REDIS_BACKUP_SIDECAR_ENABLED=false
REDIS_BACKUP_CADENCE_SECONDS=86400
REDIS_BACKUP_DRY_RUN=true
REDIS_BACKUP_SIDECAR_RUN_ONCE=false
REDIS_BACKUP_GIT_REPOSITORY=git@github.com:de-angelov/country-ranking.online-backups.git
# Required when REDIS_BACKUP_DRY_RUN=false and the repository uses SSH.
# REDIS_BACKUP_SSH_KEY_PATH=/home/deploy/.ssh/country_rank_backup_key
REDIS_BACKUP_BRANCH=main
REDIS_BACKUP_PATH=redis
REDIS_BACKUP_RETENTION_COUNT=30
