{
  "name": "country-ranking",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "compose:dev": "node scripts/compose-dev.mjs",
    "compose:dev:seed": "node scripts/compose-dev-seed.mjs",
    "compose:prod": "docker compose --profile backup up -d web-proxy app-server redis redis-backup",
    "compose:prod:down": "docker compose --profile backup down",
    "compose:prod:logs": "docker compose --profile backup logs -f web-proxy app-server redis redis-backup",
    "compose:prod:ps": "docker compose --profile backup ps",
    "compose:prod:update": "git pull && npm run compose:prod:down && npm run compose:prod",
    "dev": "react-router dev",
    "generate:banner-assets": "node scripts/generate-banner-assets.mjs",
    "generate:country-fixtures": "node scripts/generate-country-fixtures.mjs",
    "download:country-flags": "node scripts/download-country-flags.mjs",
    "lint": "react-router typegen && eslint . --max-warnings=0",
    "redis:backup:dry-run": "node scripts/backup-redis.mjs --dry-run",
    "redis:backup:push": "node scripts/backup-redis.mjs --push",
    "redis:backup:sidecar": "node scripts/redis-backup-sidecar.mjs",
    "redis:restore": "node scripts/restore-redis.mjs",
    "redis:restore:local": "node scripts/local-redis-restore.mjs",
    "redis:seed": "node scripts/seed-redis-votes.mjs",
    "start": "react-router-serve ./build/server/index.js",
    "test": "react-router typegen && vitest run",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-slot": "^1.3.0",
    "@react-router/node": "7.18.1",
    "@react-router/serve": "7.18.1",
    "@tailwindcss/vite": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "isbot": "^5.1.36",
    "lucide-react": "^1.24.0",
    "neverthrow": "^8.2.0",
    "pino": "^10.3.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "7.18.1",
    "redis": "^6.1.0",
    "remeda": "^2.30.0",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "ts-pattern": "^5.8.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@react-router/dev": "7.18.1",
    "@types/node": "^20.19.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "sharp": "^0.35.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
